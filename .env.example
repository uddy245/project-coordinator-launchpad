# ==========================================================================
# .env.example — Project Coordinator Launchpad
# Copy to .env.local and fill in values. Never commit .env.local.
# ==========================================================================

# --------------------------------------------------------------------------
# Supabase
# --------------------------------------------------------------------------
# Get from supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to client.
# Used by server actions (when RLS must be bypassed) and by the grading edge function.
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------------------------------------
# Anthropic Claude API
# --------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Pinned model for grading. Bumping requires PR + regression against calibration corpus.
ANTHROPIC_MODEL=claude-sonnet-4-5

# Daily cost cap in USD. Grading edge function refuses to run if day's spend exceeds.
ANTHROPIC_SPEND_CAP_USD=100

# --------------------------------------------------------------------------
# Stripe
# --------------------------------------------------------------------------
# Test keys during dev, live keys in Vercel prod env only.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — different for local (stripe-cli forward) vs prod.
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID for the $749 program purchase.
STRIPE_PRICE_ID=

# --------------------------------------------------------------------------
# Bunny Stream (video hosting)
# --------------------------------------------------------------------------
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=

# --------------------------------------------------------------------------
# App URLs
# --------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------------------------------
# Observability
# --------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --------------------------------------------------------------------------
# Email (transactional)
# --------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@launchpad.app
